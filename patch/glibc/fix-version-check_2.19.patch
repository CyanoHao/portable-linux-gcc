+++ b/configure.ac
@@ -986,7 +986,7 @@ AC_CHECK_PROG_VER(LD, $LD, --version,
 # These programs are version sensitive.
 AC_CHECK_TOOL_PREFIX
 AC_CHECK_PROG_VER(CC, ${ac_tool_prefix}gcc ${ac_tool_prefix}cc, -v,
