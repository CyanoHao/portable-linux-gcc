diff --git a/elf/Makefile b/elf/Makefile
index 72aa0d9572..1b1c64b0d9 100644
--- a/elf/Makefile
+++ b/elf/Makefile
@@ -285,7 +285,7 @@ $(objpfx)ld.so: $(objpfx)librtld.os $(ld-map)
 		  $(LDFLAGS-rtld) -Wl,-z,defs -Wl,--verbose 2>&1 |	\
