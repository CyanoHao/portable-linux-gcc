diff --git a/Makerules b/Makerules
index 5d7b24f31f..d435f4382a 100644
--- a/Makerules
+++ b/Makerules
@@ -572,6 +572,7 @@ build-module-helper-objlist = \
 	$(patsubst %_pic.a,$(whole-archive) %_pic.a $(no-whole-archive),\
